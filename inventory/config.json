{
  "general": {
    "url": "https://wolt.com/{lang}/isr/tel-aviv/venue/wolt-market-herzliya",
    "max_retries": 3,
    "timeout": 30
  },
  "selenium": {
    "headless": true,
    "browser": "safari",
    "proxy": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 9050
    }
  },
  "database": {
    "path": "data/shufersal_scraper.db",
    "cache_size": 100
  },
  "scraping": {
    "categories": ["en", "he"],
    "scrape_interval": 60,
    "concurrent_requests": 5
  },

  "tor": {
    "enabled": true
  }
}