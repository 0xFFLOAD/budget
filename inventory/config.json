{
  "general": {
    "url": "https://www.shufersal.co.il",
    "max_retries": 3,
    "timeout": 30
  },
  "selenium": {
    "headless": true,
    "proxy": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 9050
    }
  },
  "database": {
    "path": "data/shufersal_scraper.db",
    "cache_size": 100
  },
  "scraping": {
    "categories": ["dairy", "produce", "bakery"],
    "scrape_interval": 60,
    "concurrent_requests": 5
  },
  "tor": {
    "enabled": true
  }
}